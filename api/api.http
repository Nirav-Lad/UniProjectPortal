### Student - Idea submission request for students per their group and only group members can make it
POST http://127.0.0.1:8000/ideas/submit/ HTTP/1/1
Authorization: Bearer 
Content-Type: application/json

{
    "idea_id":2,
    "title": "Solar-Powered Microgrid Network",
    "broad_area": "Renewable Energy",
    "objective": "To create a decentralized solar energy system for rural electrification.",
    "originality_innovativeness": "Combines solar panels with blockchain for transparent energy trading.",
    "key_activities": "Install solar units, develop blockchain platform, train local operators.",
    "data_sources": "Solar energy output, local energy consumption stats, weather data.",
    "technology_usage": "Solar panels, blockchain, IoT sensors, Node.js.",
    "scalability": "Applicable to any off-grid region with sunlight availability.",
    "social_impact": "Provides reliable power to remote areas, reducing energy poverty.",
    "potent_users": "Rural households, small businesses, community centers."
}

